      "title": "Message Rate by Type",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (port_num) (rate(meshtastic_proxy_messages_total[$__rate_interval]))", "legendFormat": "{{port_num}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total messages proxied since start.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
