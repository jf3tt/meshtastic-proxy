      "title": "Errors",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_node_connection_errors_total", "legendFormat": "", "refId": "A" }
      ]
