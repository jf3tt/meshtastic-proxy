      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Whether the Meshtastic node TCP connection is up or down.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Down" }, "1": { "color": "green", "text": "Up" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showPercentChange": false, "textMode": "auto", "wideLayout": true },
      "title": "Node Status",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_node_connected", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Time since the proxy process started.",
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showPercentChange": false, "textMode": "auto", "wideLayout": true },
      "title": "Uptime",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_uptime_seconds", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of currently connected proxy clients (iOS, Android, Python CLI, etc.).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showPercentChange": false, "textMode": "auto", "wideLayout": true },
      "title": "Active Clients",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_active_clients", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of known nodes in the mesh network (from cached NodeInfo).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showPercentChange": false, "textMode": "auto", "wideLayout": true },
      "title": "Mesh Nodes",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_mesh_nodes", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of frames currently held in the config cache (MyInfo, Config, ModuleConfig, Channel, NodeInfo, ConfigCompleteId).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.5 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showPercentChange": false, "textMode": "auto", "wideLayout": true },
      "title": "Config Cache Frames",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_config_cache_frames", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Time since the config cache was last populated from the node.",
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 3600 }, { "color": "red", "value": 86400 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showPercentChange": false, "textMode": "auto", "wideLayout": true },
      "title": "Cache Age",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_config_cache_age_seconds", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Meshtastic protocol frames per second in each direction.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisLabel": "frames/s", "fillOpacity": 15, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "To Node" }, "properties": [ { "id": "custom.transform", "value": "negative-Y" } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Frame Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(meshtastic_proxy_frames_from_node_total[$__rate_interval])", "legendFormat": "From Node", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(meshtastic_proxy_frames_to_node_total[$__rate_interval])", "legendFormat": "To Node", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Bytes per second of Meshtastic traffic in each direction.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "fillOpacity": 15, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false },
          "unit": "Bps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "To Node" }, "properties": [ { "id": "custom.transform", "value": "negative-Y" } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 8,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Byte Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(meshtastic_proxy_bytes_from_node_total[$__rate_interval])", "legendFormat": "From Node", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(meshtastic_proxy_bytes_to_node_total[$__rate_interval])", "legendFormat": "To Node", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Cumulative bytes transferred since proxy start.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "fillOpacity": 15, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 9,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Total Traffic",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_bytes_from_node_total", "legendFormat": "From Node", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "meshtastic_proxy_bytes_to_node_total", "legendFormat": "To Node", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
